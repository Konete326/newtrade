PORT=5000
NODE_ENV=production

MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/trader?retryWrites=true&w=majority

JWT_SECRET=replace_with_32_plus_char_random_string
JWT_REFRESH_SECRET=replace_with_32_plus_char_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

FIELD_ENCRYPTION_KEY=replace_with_exactly_32_chars!

SUPER_ADMIN_EMAIL=admin@traderdesktop.com
SUPER_ADMIN_PASSWORD=replace_with_strong_password
SUPER_ADMIN_NAME=Super Admin

# Comma-separated list of allowed frontend origins
# Local: http://localhost:5173
# Vercel: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=trader-desktop

REDIS_URL=

GEMINI_API_KEY=your_gemini_api_key
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
